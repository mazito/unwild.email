{
  "name": "unwild",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["lib", "server", "app"],
  "scripts": {
    "dev:server": "bun --watch server/src/main.ts",
    "dev:app": "bun --cwd app run dev",
    "build:app": "bun --cwd app run build",
    "build": "bun run build:app",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --pretty",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run lint && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "@types/bun": "latest"
  }
}
